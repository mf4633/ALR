import matplotlib.pyplot as plt
import pandas as pd
import os

# Load the results from the Simulation Master
path = os.path.join(os.path.expanduser('~'), 'Documents', 'ICWMM_Analysis', 'alr_peak_scour_report.csv')
df = pd.read_csv(path)

plt.style.use('seaborn-v0_8-whitegrid')
fig, ax1 = plt.subplots(figsize=(10, 6))

# Plot Bed Shear vs Time
ax1.set_xlabel('Simulation Time')
ax1.set_ylabel('Bed Shear Stress (lb/ft²)', color='tab:red')
ax1.plot(df['time'], df['bed_shear_stress'], color='tab:red', label='ALR Bed Shear')
ax1.axhline(y=0.15, color='black', linestyle='--', label='Critical Shear (Sand)')

# Plot Particle Density (to show Adaptive Resolution working)
ax2 = ax1.twinx()
ax2.set_ylabel('Active Quanta (Particles)', color='tab:blue')
ax2.fill_between(df['time'], df['n_particles'], alpha=0.2, color='tab:blue', label='Resolution Density')

plt.title('Vortex Method Validation: Bed Shear vs. Resolution Density')
plt.show()